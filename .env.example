PORT=3000

# Upstream OpenAI-compatible service.
# Examples:
# UPSTREAM_BASE_URL=https://api.openai.com
# UPSTREAM_BASE_URL=https://api.example.com
# UPSTREAM_BASE_URL=https://api.inprior.com/v1
UPSTREAM_BASE_URL=https://api.openai.com
UPSTREAM_API_KEY=replace-with-your-upstream-api-key

# Admin key for this local relay dashboard.
# Use this key to create downstream API keys and view logs.
LOCAL_API_KEY=your-local-demo-key

# Optional static downstream keys for cloud deploys.
# Format: name:key,name2:key2
# Example:
# DOWNSTREAM_API_KEYS=tavern:sk-relay-change-this-long-random-string
DOWNSTREAM_API_KEYS=

# Optional fallback model list. The relay will first try to read:
# ${UPSTREAM_BASE_URL}/v1/models
# If that fails, it returns MODELS instead.
# For DeepSeek you might use:
# MODELS=deepseek-chat,deepseek-reasoner
MODELS=gpt-4o-mini

# Model list mode:
# merge    = read upstream /v1/models, then append MODELS
# upstream = only use upstream /v1/models
# fallback = only use MODELS
MODEL_LIST_MODE=merge

# Optional comma-separated model aliases.
# Format: local-name:upstream-name,another-local:another-upstream
# Example: demo-chat:gpt-4o-mini
MODEL_ALIASES=
